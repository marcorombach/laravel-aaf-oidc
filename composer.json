{
    "name": "marcorombach/laravel-aaf-oidc",
    "description": "This is my package laravel-aaf-oidc",
    "keywords": [
        "marcorombach",
        "laravel",
        "laravel-aaf-oidc"
    ],
    "homepage": "https://github.com/marcorombach/laravel-aaf-oidc",
    "license": "MIT",
    "authors": [
        {
            "name": "Marco Rombach",
            "email": "marco@marcorombach.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/contracts": "^9.0",
        "jumbojett/openid-connect-php": "^0.9.5",
        "spatie/laravel-package-tools": "^1.9.2"
    },
    "require-dev": {
        "nunomaduro/collision": "^6.0",
        "orchestra/testbench": "^7.0",
        "pestphp/pest": "^1.21",
        "pestphp/pest-plugin-laravel": "^1.1",
        "phpunit/phpunit": "^9.5",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "Marcorombach\\LaravelAafOIDC\\": "src",
            "Marcorombach\\LaravelAafOIDC\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marcorombach\\LaravelAafOIDC\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Marcorombach\\LaravelAafOIDC\\LaravelAafOIDCServiceProvider"
            ],
            "aliases": {
                "LaravelAafOIDC": "Marcorombach\\LaravelAafOIDC\\Facades\\LaravelAafOIDC"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
